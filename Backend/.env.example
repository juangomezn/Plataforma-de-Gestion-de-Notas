# Copia este archivo como .env y rellena los valores.
# Nunca subas .env al repositorio.

# --- Entorno ---
NODE_ENV=development

# --- Servidor Express ---
APP_PORT=3000
APP_HOSTNAME=localhost

# Origen del frontend (CORS y redirects tras login con Google)
FRONTEND_URL=http://localhost:5173

# Secret para firmar la cookie de sesión (usa una cadena larga y aleatoria en producción)
SESSION_SECRET=

# --- MongoDB ---
# Desarrollo: URI local o Atlas
MONGO_URL_LOCAL=
# Producción: solo se usa si NODE_ENV=production
MONGO_URL_PROD=

# --- Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Con Vite en desarrollo, el callback debe pasar por el proxy del front, por ejemplo:
# GOOGLE_CALLBACK_URL=http://localhost:5173/api/auth/google/callback
# Si el front llama directo al backend (sin /api), usarías:
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
GOOGLE_CALLBACK_URL=
